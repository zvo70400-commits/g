-- ОСНОВНОЙ ЦИКЛ
-- =========================================================
local function run()
    print("🐾 Synapse Z Auto Scanner Started")
    
    -- Ждём загрузки
    repeat task.wait() until lp
    task.wait(2)
    
    -- Пропускаем лоадинг (несколько раз для гарантии)
    skipLoading()
    task.wait(1)
    skipLoading()
    task.wait(1)
    
    local pets = scanWildPets()
    print(string.format("📊 Found: %d pets", #pets))

    if #pets > 0 then
        sendToDiscord(pets, game.JobId)
        task.wait(2)
    end
    
    print("🔄 Hopping...")
    doHop()
end

