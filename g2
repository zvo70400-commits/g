-- Функция форматирования денег
local function formatMoney(v)
    if not v then return "?" end
    if v >= 1e6 then return string.format("%.1fM", v / 1e6) end
    if v >= 1e3 then return string.format("%.1fK", v / 1e3) end
    return tostring(v)
end

-- 1. ПРОПУСК ЗАГРУЗКИ (клик по экрану)
local function skipLoading()
    local playerGui = lp:FindFirstChild("PlayerGui")
    if playerGui then
        local loadingGui = playerGui:FindFirstChild("LoadingGui")
        if loadingGui then
            for _, btn in ipairs(loadingGui:GetDescendants()) do
                if btn:IsA("TextButton") then
                    pcall(function() btn:Click() end)
                end
            end
        end
    end
end

-- 2. СКАНЕР ПИТОМЦЕВ
local function scanWildPets()
    local results = {}
    local map = Workspace:FindFirstChild("Map")
    if not map then return results end
    local wildPets = map:FindFirstChild("WildPetSpawns")
    if not wildPets then return results end

    for _, pet in ipairs(wildPets:GetChildren()) do
        if pet:IsA("Model") and pet.Name and string.find(pet.Name, "WildPet_") then
            local petType = nil
            for name in pairs(PET_PRICES) do
                if string.find(pet.Name, name) then
                    petType = name
                    break
                end
            end
            if petType and PET_PRICES[petType] then
                local root = pet:FindFirstChild("RootPart")
                local timeLeft = "Unknown"
                if root then
                    local timer = root:FindFirstChild("PetLeaveTimer")
                    if timer then
                        local label = timer:FindFirstChild("TextLabel")
                        if label and label.Text then timeLeft = label.Text end
                    end
                end
                table.insert(results, {pet = petType, price = PET_PRICES[petType], timeLeft = timeLeft})
            end
        end
    end
    return results
end

-- 3. ОТПРАВКА В DISCORD
local function getRequester()
    if http_request then return http_request end
    if request then return request end
    if syn and syn.request then return syn.request end
    if fluxus and fluxus.request then return fluxus.request end
    if KRNL_HTTP and KRNL_HTTP.request then return KRNL_HTTP.request end
    return nil
end

local function getPetsHash(pets)
    if #pets == 0 then return "" end
    local str = ""
    for _, p in ipairs(pets) do str = str .. p.pet .. p.timeLeft end
    return str
end

local function sendToDiscord(pets, serverId)
    local req = getRequester()
    if not req or #pets == 0 then return end

    local hash = getPetsHash(pets)
    if getgenv().GLOBAL_PET_HASHES[hash] then return end
    getgenv().GLOBAL_PET_HASHES[hash] = os.time()

    local lines = {}
    for _, p in ipairs(pets) do
        table.insert(lines, string.format("🐾 **%s** - %s | ⏰ %s", p.pet, formatMoney(p.price), p.timeLeft))
    end

    local payload = {
        username = "🐾 Scanner",
        embeds = {{
            title = "Wild Pets Found!",
            description = table.concat(lines, "\n"),
            color = 0x44FF44,
            footer = {text = string.format("Server: %s", string.sub(serverId, 1, 8))}
        }}
    }

    pcall(function()
        req({Url = WEBHOOK, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(payload)})
        print("✅ Discord: OK")
    end)
end

-- 4. ХОППЕР (РАБОЧАЯ ВЕРСИЯ, БЕЗ ЗАВИСАНИЙ)
local PLACE_ID = game.PlaceId
local cursor = nil
local recentServers = {}
local teleporting = false

local function fetchServers()
    local servers = {}
    local url = string.format("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100", PLACE_ID)
    if cursor then url = url .. "&cursor=" .. cursor end

    local ok, res = pcall(game.HttpGet, game, url)
    if not ok then return {} end
    local ok2, data = pcall(HttpService.JSONDecode, HttpService, res)
    if not ok2 or not data or not data.data then return {} end

    cursor = data.nextPageCursor
    for _, srv in ipairs(data.data) do
        if srv.playing and srv.playing >= 1 and srv.playing <= 12 then
            if not recentServers[srv.id] and srv.id ~= game.JobId then
                table.insert(servers, srv)
            end
        end
    end
    return servers
end

local function doHop()
    if teleporting then return end

    local servers = fetchServers()
    if #servers == 0 then
        print("⚠️ No servers found, waiting...")
        task.wait(5)
        return
    end

    local target = servers[math.random(#servers)]
    print(string.format("🚀 Hop to %s (%d players)", string.sub(target.id, 1, 8), target.playing))
    recentServers[target.id] = true
    getgenv().GLOBAL_SERVER_BLACKLIST[target.id] = true
    teleporting = true

    task.wait(1)
    pcall(function()
        TeleportService:TeleportToPlaceInstance(PLACE_ID, target.id, lp)
    end)
    teleporting = false
end

-- 5. ОСНОВНОЙ ЦИКЛ (ПРОСТОЙ И ПОНЯТНЫЙ)
local function runCycle()
    print("===================================")
    print("🐾 SCAN CYCLE START")
    
    -- Ждем пока персонаж появится (но не вечно)
    local waitTime = 0
    while (not lp or not lp.Character) and waitTime < 15 do
        task.wait(1)
        waitTime = waitTime + 1
        print("Wait for character...", waitTime)
    end
    
    if not lp or not lp.Character then
        print("⚠️ Character not loaded, hopping anyway")
    end
    
    skipLoading()
    task.wait(2)
    
    -- Сканируем
    local pets = scanWildPets()
    print(string.format("📊 Found: %d pets", #pets))
    
    -- Отправляем, если есть
    if #pets > 0 then
        sendToDiscord(pets, game.JobId)
        task.wait(2)
    end
    
    -- Хопаем
    doHop()
end

