local function run()
    print("🐾 Scanner Started")
    
    -- Ждём игрока
    local lp = nil
    local waitTime = 0
    while not lp and waitTime < 30 do
        lp = getLocalPlayer()
        if not lp then
            task.wait(1)
            waitTime = waitTime + 1
        end
    end
    
    if not lp then
        print("❌ LocalPlayer not found after 30 seconds, retrying...")
        return
    end
    
    print("✅ LocalPlayer found: " .. (lp.Name or "Unknown"))
    
    task.wait(2)
    skipLoading()
    task.wait(1)
    
    local pets = scanWildPets()
    print(string.format("📊 Found: %d pets", #pets))

    if #pets > 0 then
        sendToDiscord(pets, game.JobId)
        task.wait(2)
    end
    
    print("🔄 Hopping...")
    doHop()
end

